generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  passwordHash String?
  phone        String
  isAdmin      Boolean       @default(false)
  appointments Appointment[]
}

model Service {
  id              Int           @id @default(autoincrement())
  name            String
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  durationMinutes Int
  active          Boolean       @default(true)
  appointments    Appointment[]
}

model Appointment {
  id           Int      @id @default(autoincrement())
  startTime    DateTime @db.Timestamptz(3)
  endTime      DateTime @db.Timestamptz(3)
  status       String   @default("pending") // pending, confirmed, canceled
  isManualSlot Boolean  @default(false)     // true quando criado pela dona manualmente
  notes        String?                      // Observação opcional do agendamento manual

  clientId  Int
  serviceId Int
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  client  User    @relation(fields: [clientId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

model StudioConfig {
  id            Int      @id @default(autoincrement())
  closedDays    Int[]    @default([0])
  createdAt     DateTime @updatedAt
  closingTime   Int      @default(18)
  openingTime   Int      @default(8)
  ownerWhatsApp String?
  ownerEmail    String?  // Email da dona para receber notificações de agendamento
}

