generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String     
  passwordHash String?
  phone        String
  isAdmin      Boolean       @default(false)
  appointments Appointment[] // Relação: Um usuário tem muitos agendamentos
}

model Service {
  id              Int           @id @default(autoincrement())
  name            String
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  durationMinutes Int
  active         Boolean       @default(true)
  appointments    Appointment[]
}

model Appointment {
  id        Int      @id @default(autoincrement())
  startTime DateTime @db.Timestamptz(3)
  endTime   DateTime @db.Timestamptz(3)
  status    String   @default("pending") // Exemplo de status: pending, confirmed, canceled
  
  clientId  Int
  client    User     @relation(fields: [clientId], references: [id])
  
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(3)
}

model StudioConfig{
  id            Int      @id @default(autoincrement())
  openingTime   Int      @default(8)    // Hora de abertura do estúdio (formato 24h)
  closingTime   Int      @default(18)   // Hora de fechamento do estúdio (formato 24h)
  closedDays    Int[]    @default([0]) // Dias da semana em que o estúdio está fechado, ex: "0,6" para domingo e sábado
  createdAt     DateTime @updatedAt
}

model ClosedDate {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date // Data específica de fechamento
  reason      String?  // Motivo opcional (ex: "Férias", "Feriado")
  createdAt   DateTime @default(now())
}
